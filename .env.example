# Sueca environment template
# Copy to .env.dev / .env.prod and fill values (do NOT commit real secrets)

# ===== Database =====
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=sueca
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ===== API keys / secrets =====
JWT_SECRET=change-me-long-random

# ===== Frontend/Backend URLs =====
FRONTEND_URL=https://sueca.peixotolabs.com
CORS_ALLOWED_ORIGINS=https://sueca.peixotolabs.com
BACKEND_URL=https://api-sueca.peixotolabs.com

# ===== Container Naming =====
COMPOSE_PROJECT_NAME=sueca
CONTAINER_PREFIX=Sueca
BACKEND_HOST=Sueca_backend

# ===== Port Configuration =====
FRONTEND_PORT=80
